{
  "manifest_version": 3,
  "name": "Memora Logger",
  "description": "Captures chat prompts and AI responses from ChatGPT, Gemini, Perplexity, and Claude — logs them to your Memora session.",
  "version": "2.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://claude.ai/*",
    "http://localhost:3005/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "utils/sessionId.js",
        "utils/domWatcher.js",
        "content/chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "utils/sessionId.js",
        "utils/domWatcher.js",
        "content/gemini.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "utils/sessionId.js",
        "utils/domWatcher.js",
        "content/perplexity.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "utils/sessionId.js",
        "utils/domWatcher.js",
        "content/claude.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*"
      ],
      "js": [
        "content/userManager.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Memora Logger"
  },
  "icons": {}
}